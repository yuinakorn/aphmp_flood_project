# ──────────────────────────────────────────────────────────────
# FloodWatch น่าน — Environment Variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ──────────────────────────────────────────────────────────────

# Database — PostgreSQL + PostGIS
# เช่น Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# หรือ Neon:     postgresql://[USER]:[PASS]@[HOST]/[DB]?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/floodwatch

# NextAuth
# สร้าง secret ด้วย: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Provider ID SSO Portal
# redirect URI สำหรับ NextAuth ต้องลงทะเบียนใน SSO Portal แบบ exact match:
# http://localhost:3000/api/auth/callback/provider-id-sso
SSO_URL=https://sso.example.go.th
SSO_CLIENT_ID=your-client-id
SSO_CLIENT_SECRET=your-client-secret
SSO_REDIRECT_URI=http://localhost:3000/api/auth/callback/provider-id-sso

# GISTDA API (optional — สำหรับ WMS layer)
GISTDA_API_KEY=

# Google Earth Engine Service Account (optional — สำหรับ ingest pipeline)
GEE_SERVICE_ACCOUNT=
GEE_PRIVATE_KEY=
